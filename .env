NGROK_AUTHTOKEN=3FFoqFOoVRE9XhDvqu2of7C9Rsa_CSknSd37t6befdvq7ktw

ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_CONFIDENCE=0.35
ROBOFLOW_DETECTION_INTERVAL=1.0
ROBOFLOW_TIMEOUT_SECONDS=8.0

# ===================================
# CAMERA CONFIGURATION
# ===================================
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=15

# ===================================
# PERFORMANCE TUNING PARAMETERS
# ===================================
# Detection frame resolution (lower = faster inference)
# Default: 416x416 (6-8x faster than 640x480)
DETECTION_FRAME_WIDTH=416
DETECTION_FRAME_HEIGHT=416

# JPEG compression quality for detection frames (1-100)
# Default: 65 (good balance)
DETECTION_JPEG_QUALITY=65

# JPEG compression quality for streaming (1-100)
# Default: 70 (visually better than detection)
STREAM_JPEG_QUALITY=70

# Frame skipping for detection processing
# 1 = process all frames, 2 = skip every other, etc
# Default: 1 (process all)
FRAME_SKIP=1

# Maximum frames per second for streaming
# Default: 12 (reduces bandwidth vs 15)
MAX_STREAMING_FPS=12

# ===================================
# FLASK SERVER CONFIGURATION
# ===================================
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5005

# ===================================
# SERIAL COMMUNICATION (Optional)
# ===================================
# Uncomment to enable ESP32 serial monitoring
# SERIAL_PORT=/dev/ttyUSB0
# SERIAL_BAUDRATE=115200

# ===================================
# DATABASE & LAPTOP AI (Optional)
# ===================================
DB_URI=mongodb+srv://admin:ADMIN123@cluster0.9gqnvps.mongodb.net/crayfish_db?retryWrites=true&w=majority&appName=Cluster0
LAPTOP_AI_URL=http://10.62.190.93:8000/detect